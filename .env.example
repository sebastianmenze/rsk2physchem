# CTD Profile Browser – environment configuration
# Copy this file to .env and fill in real values before running.

# ── Toktlogger API
TOKTLOGGER_CRUISES_URL=http://toktlogger-hansb.hi.no/api/cruises/all
TOKTLOGGER_ACTIVITIES_URL=http://toktlogger-hansb.hi.no/api/activities/inPeriod

# ── S3 / PhysChem object storage
S3_ENDPOINT_URL=https://s3.hi.no
S3_ACCESS_KEY_ID=your-access-key-here
S3_SECRET_ACCESS_KEY=your-secret-key-here
S3_BUCKET=transient-data
S3_DEST_PREFIX=physchem/incoming/regular_stations/test/
